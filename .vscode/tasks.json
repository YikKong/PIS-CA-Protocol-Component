{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build PIS-CA Project",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "-std=c++17",
                "${workspaceFolder}/src/*.cpp",
                "-I${workspaceFolder}/include",
                "-o",
                "${workspaceFolder}/PIS-CA.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$msCompile"],
            "detail": "编译整个 PIS-CA 项目"
        },
        {
            "label": "Build Current File",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "${file}",
                "-I${workspaceFolder}/include",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe"
            ],
            "group": "build",
            "problemMatcher": ["$msCompile"]
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "del",
            "args": [
                "${workspaceFolder}/*.exe",
                "${workspaceFolder}/*.o"
            ],
            "group": "build"
        }
    ]
}