{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "make build dir",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/c",
        "if not exist build mkdir build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "build pisca protocol test",
      "type": "shell",
      "command": "Z:/MSY2/ucrt64/bin/g++.exe",
      "args": [
        "PIS-CA Refactor/tests/pisca_protocol_test.cpp",
        "PIS-CA Refactor/PIS-CA/PISCAProtocol.cpp",
        "PIS-CA Refactor/PIS-CA/SigmaCiphertextArgument.cpp",
        "PIS-CA Refactor/CamenischShoup/CamenischShoupEnc.cpp",
        "PIS-CA Refactor/CamenischShoup/CamenischShoupEncZKP.cpp",
        "PIS-CA Refactor/ElGamal/ElGamalEnc.cpp",
        "PIS-CA Refactor/Curdleproofs/Curdleproofs.cpp",
        "PIS-CA Refactor/Curdleproofs/ElGamalCommitment/ElGamalCommitment.cpp",
        "PIS-CA Refactor/Curdleproofs/SameSalar Argument/SameScalarArgument.cpp",
        "PIS-CA Refactor/Curdleproofs/SameMultiScalar Argument/SameMultiScalarArgument.cpp",
        "PIS-CA Refactor/Curdleproofs/SamePermutation Argument/SamePermutationArgument.cpp",
        "-std=c++17",
        "-O0",
        "-Wall",
        "-Wextra",
        "-I",
        "Z:/MSY2/ucrt64/include",
        "-L",
        "Z:/MSY2/ucrt64/lib",
        "-o",
        "build/pisca_protocol_test.exe",
        "-lntl",
        "-lgmp",
        "-lssl",
        "-lcrypto"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "Z:/MSY2/ucrt64/bin;${env:PATH}"
        }
      },
      "dependsOn": "make build dir",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
