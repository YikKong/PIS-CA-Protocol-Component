{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "make build dir",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/c",
        "if not exist build mkdir build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "build same scalar argument test",
      "type": "shell",
      "command": "Z:/MSY2/ucrt64/bin/g++.exe",
      "args": [
        "PIS-CA Refactor/tests/same_scalar_argument_test.cpp",
        "PIS-CA Refactor/Curdleproofs/SameSalar Argument/SameScalarArgument.cpp",
        "PIS-CA Refactor/Curdleproofs/ElGamalCommitment/ElGamalCommitment.cpp",
        "PIS-CA Refactor/ElGamal/ElGamalEnc.cpp",
        "-std=c++17",
        "-O0",
        "-Wall",
        "-Wextra",
        "-I",
        "Z:/MSY2/ucrt64/include",
        "-L",
        "Z:/MSY2/ucrt64/lib",
        "-o",
        "build/same_scalar_argument_test.exe",
        "-lssl",
        "-lcrypto"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "Z:/MSY2/ucrt64/bin;${env:PATH}"
        }
      },
      "dependsOn": "make build dir",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "run same scalar argument test",
      "type": "shell",
      "command": "build/same_scalar_argument_test.exe",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "Z:/MSY2/ucrt64/bin;${env:PATH}"
        }
      },
      "dependsOn": "build same scalar argument test",
      "problemMatcher": []
    }

    /*
    Other compile/run tasks are intentionally commented out while working on
    SameScalarArgument.

    Previous tasks:
    - build elgamal enc test
    - run elgamal enc test
    - build elgamal commitment test
    - run elgamal commitment test
    - build camenisch shoup enc zkp test
    - run camenisch shoup enc zkp test
    - build pisca protocol test
    - run pisca protocol test
    - build crypto tests
    - run crypto tests
    */
  ]
}
